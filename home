
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GONE WEST 2025</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #111;
      color: #fff;
    }

    h1 {
      text-align: center;
      padding: 20px;
    }

    .container {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 15px;
      padding: 20px;
    }

    .section {
      background: #222;
      border-radius: 12px;
      overflow: hidden;
      aspect-ratio: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      cursor: pointer;
    }

    .section img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: none;
    }

    .section span {
      position: absolute;
      color: #aaa;
      font-size: 14px;
      text-align: center;
      padding: 10px;
    }
  </style>
</head>
<body>

<h1>GONE WEST 2025</h1>

<div class="container"></div>


<script>
  const container = document.querySelector('.container');


  // 🚨 PUT YOUR FREE API KEY HERE (instructions below)
  const API_KEY = "21200bc93855f58f4bb4cbfb68f8dc39";


  for (let i = 1; i <= 29; i++) {
    const div = document.createElement('div');
    div.className = 'section';


    const input = document.createElement('input');
    input.type = 'file';
    input.accept = 'image/*';
    input.style.display = 'none';


    const img = document.createElement('img');
    const label = document.createElement('span');


    const savedUrl = localStorage.getItem('img-url-' + i);


    if (savedUrl) {
      img.src = savedUrl;
      img.style.display = 'block';
    } else {
      label.innerText = "Click to upload image " + i;
    }

    div.appendChild(img);
    div.appendChild(label);
    div.appendChild(input);


    div.onclick = () => input.click();

    input.onchange = async () => {
      const file = input.files[0];
      if (!file) return;
      const formData = new FormData();
      formData.append("image", file);
      try {
        const res = await fetch(`https://api.imgbb.com/1/upload?key=${API_KEY}`, {
          method: "POST",
          body: formData
        });
        const data = await res.json();
        const imageUrl = data.data.url;
        img.src = imageUrl;
        img.style.display = 'block';
        label.style.display = 'none';


        // Save URL so it reloads
        localStorage.setItem('img-url-' + i, imageUrl);


      } catch (err) {
        alert("Upload failed — check API key");
        console.error(err);
      }
    };

    container.appendChild(div);
  }
</script>

</body>
